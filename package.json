{
  "name": "tbl-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"astro,images\" --prefix-colors \"cyan,magenta\" \"astro dev\" \"node scripts/convert-pngs-to-jpgs.mjs\"",
    "start": "npm run dev",
    "build": "npm run convert-images && astro build",
    "preview": "astro preview",
    "convert-images": "node scripts/convert-pngs-to-jpgs.mjs --once",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/tailwind": "^5.1.4",
    "astro": "^4.16.18",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1"
  }
}
