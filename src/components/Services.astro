---
import { siteContent } from '../content/site';
const { services } = siteContent;
---

<section id="services" class="section">
  <div class="container-edge">
    <div class="text-center max-w-2xl mx-auto">
      <p class="eyebrow eyebrow-divider">WHAT WE DO</p>
      <h2 class="headline headline-section mt-8">Every detail, handled.</h2>
    </div>

    <div class="mt-16 md:mt-20 grid gap-10 md:grid-cols-3">
      {
        services.map((s) => (
          <article class="group">
            <a href={s.href} class="block overflow-hidden">
              <div class="aspect-[4/5] overflow-hidden">
                <img
                  src={s.image}
                  alt={s.title}
                  class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </a>
            <div class="mt-6">
              <p class="eyebrow">{s.eyebrow}</p>
              <h3 class="headline text-2xl md:text-[28px] leading-[1.15] mt-3">
                {s.title}
              </h3>
              <p class="body-copy mt-4 text-base">{s.blurb}</p>
              <a href={s.href} class="link-underline mt-6 inline-block">
                Learn more
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
