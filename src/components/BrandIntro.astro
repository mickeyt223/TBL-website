---
import { siteContent } from '../content/site';
const { brandIntro } = siteContent;
---

<section id="brand-intro" class="section">
  <div class="container-edge">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16">
      <div class="md:pr-8">
        <h2 class="headline text-4xl md:text-5xl lg:text-6xl">
          {brandIntro.title}
        </h2>
        <p class="mt-6 font-body text-lg md:text-xl font-bold text-ivory">
          {brandIntro.subtitle}
        </p>
        <p class="mt-4 body-copy">
          {brandIntro.description}
        </p>
      </div>

      <div class="md:pl-8 md:border-l md:border-ivory/15 space-y-5">
        {
          brandIntro.paragraphs.map((p) => (
            <p class="body-copy">{p}</p>
          ))
        }
      </div>
    </div>
  </div>
</section>
