---
import { siteContent } from '../content/site';
const { brandIntro } = siteContent;
---

<section id="brand-intro" class="section">
  <div class="container-edge text-center max-w-3xl">
    <p class="eyebrow eyebrow-divider">{brandIntro.eyebrow}</p>
    <h2 class="headline headline-section mt-8">{brandIntro.headline}</h2>
    <p class="body-copy mt-6">{brandIntro.body}</p>
  </div>
</section>
