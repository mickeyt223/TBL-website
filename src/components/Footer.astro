---
import { siteContent } from '../content/site';
const { business, footer } = siteContent;
const year = new Date().getFullYear();
---

<footer class="bg-background border-t border-brass/20 text-ivory">
  <div class="container-edge py-16 md:py-20 grid gap-12 md:grid-cols-3">
    <div>
      {
        business.logo ? (
          <img
            src={business.logoFooter ?? business.logo}
            alt={business.logoAlt ?? business.name}
            class="h-48 md:h-56 w-auto"
            width="224"
            height="224"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <p class="font-display text-2xl tracking-wide">{business.name}</p>
        )
      }
      <p class="mt-3 font-body text-sm text-muted max-w-xs">{footer.tagline}</p>
      <div class="mt-6 flex gap-4">
        {
          business.socials.instagram && (
            <a
              href={business.socials.instagram.startsWith('http') ? business.socials.instagram : `https://instagram.com/${business.socials.instagram.replace('@', '')}`}
              class="text-muted hover:text-brass transition-colors"
              aria-label="Instagram"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
                <rect x="3" y="3" width="18" height="18" rx="4"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
              </svg>
            </a>
          )
        }
        {
          business.socials.facebook && (
            <a
              href={business.socials.facebook}
              class="text-muted hover:text-brass transition-colors"
              aria-label="Facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          )
        }
        {
          business.socials.google && (
            <a
              href={business.socials.google}
              class="text-muted hover:text-brass transition-colors"
              aria-label="Google"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
                <circle cx="12" cy="12" r="9"/>
                <path d="M12 8v4l3 2"/>
              </svg>
            </a>
          )
        }
      </div>
    </div>

    <div>
      <p class="eyebrow text-brass">Quick Links</p>
      <ul class="mt-5 space-y-3">
        {
          footer.quickLinks.map((l) => (
            <li>
              <a href={l.href} class="font-body text-sm text-ivory/85 hover:text-brass transition-colors">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="eyebrow text-brass">Contact</p>
      <ul class="mt-5 space-y-3">
        <li>
          <a
            href={`tel:${business.phone.replace(/[^0-9+]/g, '')}`}
            class="font-body text-sm text-ivory/85 hover:text-brass transition-colors"
          >
            {business.phone}
          </a>
        </li>
        <li>
          <a
            href={`mailto:${business.email}`}
            class="font-body text-sm text-ivory/85 hover:text-brass transition-colors"
          >
            {business.email}
          </a>
        </li>
        <li>
          <p class="font-body text-sm text-muted">{business.serviceArea}</p>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-ivory/10">
    <div
      class="container-edge py-6 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between font-body text-xs text-muted"
    >
      <p>
        © {year} {business.name}. {footer.copyrightSuffix}
      </p>
      <a href="#" class="hover:text-brass transition-colors">Privacy Policy</a>
    </div>
  </div>
</footer>
